// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Users table
model User {
  id           String    @id @default(cuid())
  phoneNumber  String    @unique
  name         String
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relationships
  transactionsAsSeller Transaction[] @relation("SellerTransactions")
  transactionsAsBuyer  Transaction[] @relation("BuyerTransactions")
  
  // Add this line for Wallet relation
  wallet               Wallet?
}

// Transactions table (using String for status instead of enum)
model Transaction {
  id                 String    @id @default(cuid())
  transactionRef     String    @unique
  sellerId           String
  buyerId            String
  sellerPhone        String
  buyerPhone         String
  sellerName         String
  amount             Float
  status             String    @default("PENDING_PAYMENT")
  paymentMethod      String    @default("mpesa")
  fileHash           String?
  aiReport           String?
  mpesaReceiptNumber String?
  checkoutRequestId  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  completedAt        DateTime?
  
  // Relationships
  seller User @relation("SellerTransactions", fields: [sellerId], references: [id])
  buyer  User @relation("BuyerTransactions", fields: [buyerId], references: [id])
  
  // Related models
  files        File[]
  mpesaPayments MpesaPayment[]
}

// Files table
model File {
  id         String   @id @default(cuid())
  hash       String   @unique
  filename   String
  size       Int
  mimeType   String?
  uploadedAt DateTime @default(now())
  
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
}

// M-Pesa Payment table (using String for status instead of enum)
model MpesaPayment {
  id                 String    @id @default(cuid())
  transactionId      String
  checkoutRequestId  String    @unique
  mpesaReceiptNumber String?
  amount             Float
  phoneNumber        String
  resultCode         Int?
  resultDesc         String?
  status             String    @default("PENDING")
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
  
  transaction Transaction @relation(fields: [transactionId], references: [id])
}

// Wallet table
model Wallet {
  id           String    @id @default(cuid())
  userId       String    @unique
  balance      Float     @default(0)
  currency     String    @default("KES")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relationships
  user         User      @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

// Wallet Transaction table
model WalletTransaction {
  id           String    @id @default(cuid())
  walletId     String
  amount       Float
  type         String    // 'credit', 'debit'
  status       String    // 'pending', 'completed', 'failed'
  description  String?
  balanceAfter Float
  createdAt    DateTime  @default(now())
  
  // Relationships
  wallet       Wallet    @relation(fields: [walletId], references: [id])
}